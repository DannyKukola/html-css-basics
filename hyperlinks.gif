
<!-- Hyperlink: A digital reference to data that a user can follow by clicking or tapping a button or a link.-->

<!DOCTYPE html>
<html lang="en">
<head>
    <title>Document</title>
</head>
<body>

    <a href="https://en.wikipedia.org/wiki/Main_Page" 
    target ="_blank" title="Goes to wikipedia."> <!-- Anchor tags. HREF attribute: An attribute is a
        name-value pair that modifies the behaviour of an element
        HREF means 'hypertext reference'-->

        <!-- Setting target to blank opens it in a new tab or a new window depending on user settings.-->

        <!-- Title adds additional information as a tool-tip. -->

    Click me 

    </a>

    <br>

    <a href="lyrics.html">

        Song lyrics 

    </a>

    <br>

    <a href="mailto: JohnDoe@gmail.com">

        Email me: 

    </a>
    
</body>
</html>